# ── Quantoz EURD — receiving account ────────────────────────────────────────
# Create an account at https://quantozpay.com to get these
EURD_API_KEY=your-eurd-api-key
EURD_ACCOUNT_CODE=your-account-code
QUANTOZ_BASE_URL=https://api.quantozpay.com

# ── Anthropic — for AI sailing briefings ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Algorand on-chain EURD (optional — omit to disable) ─────────────────────
